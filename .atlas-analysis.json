  "keyFeatures": [
    "S3-backed markdown vault storage with Tigris integration",
    "Rich markdown editing with BlockNote and preview capabilities",
    "AI-powered chat and content actions using Vercel AI SDK",
    "File tree navigation with search and context menu operations",
    "GitHub OAuth authentication via BetterAuth",
    "Redis-backed caching for performance optimization",
    "PWA support for offline-capable installable app",
    "Streamdown-based markdown rendering with Mermaid diagram support"
  ],
  "publicApiSurface": [
    "GET /api/fs/list - List files and folders",
    "GET /api/fs/file - Retrieve file content",
    "PUT /api/fs/file - Update file content",
    "POST /api/fs/mkdir - Create folder",
    "POST /api/fs/move - Move/rename file",
    "DELETE /api/fs/file - Delete file",
    "DELETE /api/fs/folder - Delete folder",
    "GET /api/tree - Get file tree manifest",
    "POST /api/tree/refresh - Rebuild tree manifest",
    "POST /api/ai/chat - AI chat with context",
    "POST /api/ai/action - AI content actions (improve, summarize, expand)"
  ]
}
